# API keys
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here
TAVILY_KEY=your_tavily_api_key_here

# LLM provider: use "groq" for the default direct provider or "openrouter" for hosted demos.
LLM_PROVIDER=groq
GROQ_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here  # optional — fallback when Groq rate-limits
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL_LARGE=deepseek/deepseek-v4-flash
OPENROUTER_MODEL_SMALL=meta-llama/llama-3.1-8b-instruct
OPENROUTER_HTTP_REFERER=https://your-portfolio-site.example
OPENROUTER_APP_TITLE=Equity Research Agent

# HuggingFace (Phase 2 only)
HF_TOKEN=your_huggingface_token_here

# MLflow / DagsHub (Phase 2 only)
DAGSHUB_TOKEN=your_dagshub_token_here
DAGSHUB_REPO_OWNER=your_dagshub_username
DAGSHUB_REPO_NAME=financial-research-agent

# Runtime storage (Railway sets this automatically; use local path for dev)
RUNTIME_DATA_DIR=./runtime_data

# Backend / frontend URLs (legacy Streamlit only; Next.js uses frontend-next/.env.example)
BACKEND_URL=http://localhost:8000

# Model backend toggle (base or finetuned — Phase 2)
MODEL_BACKEND=base
